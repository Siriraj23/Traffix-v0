def process_video_deep(contents: bytes, suffix: str) -> Dict[str, Any]:
    """Process video frame by frame with cross-frame deduplication."""
    with tempfile.NamedTemporaryFile(delete=False, suffix=suffix) as tmp:
        tmp.write(contents)
        tmp_path = tmp.name
    
    try:
        cap = cv2.VideoCapture(tmp_path)
        if not cap.isOpened():
            raise HTTPException(status_code=400, detail="Cannot open video")
        
        total_frames = int(cap.get(cv2.CAP_PROP_FRAME_COUNT))
        fps = cap.get(cv2.CAP_PROP_FPS)
        duration = total_frames / fps if fps > 0 else 0
        
        print(f"\n🎬 VIDEO ANALYSIS")
        print(f"   Frames: {total_frames} | FPS: {fps:.1f} | Duration: {duration:.1f}s")
        print(f"   Stride: every {CONFIG['frame_stride']}th frame (max {CONFIG['max_video_frames']})")
        print("="*60)
        
        # Initialize violation tracker for cross-frame deduplication
        tracker = ViolationTracker()
        
        frame_results = []
        frame_index = 0
        processed_count = 0
        all_plates = []
        all_vehicles = []
        violation_frames = set()
        
        while True:
            success, frame = cap.read()
            if not success:
                break
            
            frame_index += 1
            
            # Skip frames based on stride
            if frame_index % CONFIG["frame_stride"] != 0:
                continue
            
            # Process frame (video mode - no fallbacks)
            result = analyze_frame_video(frame)
            result["frame_number"] = frame_index
            result["timestamp_seconds"] = round(frame_index / fps, 2) if fps > 0 else 0
            frame_results.append(result)
            processed_count += 1
            
            # Track violations with cross-frame deduplication
            frame_has_violation = False
            
            for v in result["violations"]["no_helmet"]:
                v_with_frame = v.copy()
                if tracker.add_violation("no_helmet", v_with_frame, frame_index):
                    frame_has_violation = True
            
            for v in result["violations"]["triple_riding"]:
                v_with_frame = v.copy()
                if tracker.add_violation("triple_riding", v_with_frame, frame_index):
                    frame_has_violation = True
            
            for v in result["violations"]["overloading"]:
                v_with_frame = v.copy()
                if tracker.add_violation("overloading", v_with_frame, frame_index):
                    frame_has_violation = True
            
            if frame_has_violation:
                violation_frames.add(frame_index)
            
            # Collect unique plates
            for p in result["plates"]:
                if p.get("text") and p["text"] not in [ep.get("text") for ep in all_plates]:
                    p["frame_number"] = frame_index
                    all_plates.append(p)
            
            # Collect vehicles
            all_vehicles.extend(result["vehicles"])
            
            # Progress indicator
            if processed_count % 10 == 0:
                print(f"   📊 Frame {frame_index}/{total_frames} | Unique violations: {tracker.get_total_unique()}")
            
            # Limit
            if processed_count >= CONFIG["max_video_frames"]:
                print(f"   ⚠️  Reached max frames ({CONFIG['max_video_frames']})")
                break
        
        cap.release()
        
        # Get final deduplicated violations
        unique_violations = tracker.get_unique_violations()
        
        # Sort violation frames
        sorted_violation_frames = sorted(list(violation_frames))
        
        total_violations = sum(len(v) for v in unique_violations.values())
        
        # Generate summary
        summary = {
            "total_frames": total_frames,
            "frames_processed": processed_count,
            "fps": round(fps, 2),
            "duration_seconds": round(duration, 2),
            "total_vehicles_detected": len(all_vehicles),
            "total_plates_read": len(all_plates),
            "total_unique_violations": total_violations,
            "no_helmet_cases": len(unique_violations["no_helmet"]),
            "triple_riding_cases": len(unique_violations["triple_riding"]),
            "overloading_cases": len(unique_violations["overloading"]),
            "has_violations": total_violations > 0,
            "violation_frames_count": len(sorted_violation_frames),
            "violation_timestamps": [round(f/fps, 1) for f in sorted_violation_frames[:10]] if fps > 0 else []
        }
        
        # Messages
        messages = []
        if total_violations > 0:
            messages.append(f"🚨 {total_violations} unique violations detected")
            if summary["no_helmet_cases"] > 0:
                messages.append(f"🪖 {summary['no_helmet_cases']} No Helmet - ₹1,000 each")
            if summary["triple_riding_cases"] > 0:
                messages.append(f"🏍️ {summary['triple_riding_cases']} Triple Riding - ₹2,000 each")
            if summary["overloading_cases"] > 0:
                messages.append(f"🚛 {summary['overloading_cases']} Overloading - ₹5,000 each")
        else:
            messages.append("✅ No violations detected")
        
        messages.append(f"🎬 {total_frames} frames | {processed_count} analyzed")
        messages.append(f"🚗 {summary['total_vehicles_detected']} vehicle detections")
        messages.append(f"📝 {summary['total_plates_read']} plates read")
        
        total_fine = (
            summary["no_helmet_cases"] * 1000 +
            summary["triple_riding_cases"] * 2000 +
            summary["overloading_cases"] * 5000
        )
        
        print(f"\n✅ Video Complete!")
        print(f"   Unique Violations: {total_violations}")
        print(f"   Violation Frames: {len(sorted_violation_frames)}")
        print(f"   Total Fine: ₹{total_fine:,}")
        print("="*60 + "\n")
        
        return convert_numpy({
            "success": True,
            "media_type": "video",
            "summary": summary,
            "total_fine": total_fine,
            "report": {
                "violations": unique_violations,
                "all_vehicles": all_vehicles[:20],
                "plates": all_plates[:10],
                "violation_details": unique_violations,
            },
            "detection_messages": messages,
        })
        
    finally:
        if os.path.exists(tmp_path):
            os.remove(tmp_path)


def process_image_full(contents: bytes) -> Dict[str, Any]:
    """Process single image with full analysis."""
    frame = decode_image(contents)
    result = analyze_single_frame(frame)
    
    # Draw annotated frame
    annotated_frame = frame.copy()
    
    # Draw vehicles (green)
    for v in result["vehicles"]:
        b = v["bbox"]
        cv2.rectangle(annotated_frame, (b[0],b[1]), (b[2],b[3]), (0,255,0), 2)
        cv2.putText(annotated_frame, v["type"], (b[0],b[1]-10), cv2.FONT_HERSHEY_SIMPLEX, 0.6, (0,255,0), 2)
    
    # Draw plates (yellow)
    for p in result["plates"]:
        b = p["bbox"]
        cv2.rectangle(annotated_frame, (b[0],b[1]), (b[2],b[3]), (0,255,255), 2)
        if p.get("text"):
            cv2.putText(annotated_frame, p["text"], (b[0],b[1]-10), cv2.FONT_HERSHEY_SIMPLEX, 0.5, (0,255,255), 2)
    
    # Draw no-helmet (red)
    for v in result["violations"]["no_helmet"]:
        b = v["bbox"]
        cv2.rectangle(annotated_frame, (b[0],b[1]), (b[2],b[3]), (0,0,255), 3)
        cv2.putText(annotated_frame, "NO HELMET!", (b[0],b[1]-10), cv2.FONT_HERSHEY_SIMPLEX, 0.7, (0,0,255), 2)
    
    # Draw triple riding (orange)
    for v in result["violations"]["triple_riding"]:
        b = v["bbox"]
        cv2.rectangle(annotated_frame, (b[0],b[1]), (b[2],b[3]), (0,165,255), 2)
        cv2.putText(annotated_frame, "TRIPLE!", (b[0],b[1]-10), cv2.FONT_HERSHEY_SIMPLEX, 0.6, (0,165,255), 2)
    
    # Draw overloading (purple)
    for v in result["violations"]["overloading"]:
        b = v["bbox"]
        cv2.rectangle(annotated_frame, (b[0],b[1]), (b[2],b[3]), (255,0,255), 2)
        cv2.putText(annotated_frame, "OVERLOAD!", (b[0],b[1]-10), cv2.FONT_HERSHEY_SIMPLEX, 0.6, (255,0,255), 2)
    
    _, buf = cv2.imencode('.jpg', annotated_frame)
    annotated_b64 = base64.b64encode(buf).decode('utf-8')
    
    tv = result["total_violations"]
    nh = len(result["violations"]["no_helmet"])
    tr = len(result["violations"]["triple_riding"])
    ov = len(result["violations"]["overloading"])
    
    messages = []
    if tv > 0:
        messages.append(f"🚨 Found {tv} violation(s)")
        if nh > 0: messages.append(f"🪖 {nh} No Helmet - ₹1,000 each")
        if tr > 0: messages.append(f"🏍️ {tr} Triple Riding - ₹2,000 each")
        if ov > 0: messages.append(f"🚛 {ov} Overloading - ₹5,000 each")
    else:
        messages.append("✅ No violations detected")
    messages.append(f"🚗 {len(result['vehicles'])} vehicle(s)")
    messages.append(f"📝 {len(result['plates'])} plate(s)")
    
    total_fine = nh * 1000 + tr * 2000 + ov * 5000
    
    return convert_numpy({
        "success": True,
        "media_type": "image",
        "summary": {
            "total_vehicles": len(result["vehicles"]),
            "total_plates": len(result["plates"]),
            "total_violations": tv,
            "no_helmet_cases": nh,
            "triple_riding_cases": tr,
            "overloading_cases": ov,
            "has_violations": tv > 0,
        },
        "total_fine": total_fine,
        "report": {
            "all_vehicles": result["vehicles"],
            "vehicles": result["vehicles"],
            "plates": result["plates"],
            "violations": result["violations"],
        },
        "detection_messages": messages,
        "annotated_image": annotated_b64,
    })


