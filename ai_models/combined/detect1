def convert_numpy(obj):
    """Convert numpy types to Python native types for JSON serialization."""
    if isinstance(obj, (np.integer,)): return int(obj)
    if isinstance(obj, (np.floating,)): return float(obj)
    if isinstance(obj, np.ndarray): return obj.tolist()
    if isinstance(obj, dict): return {k: convert_numpy(v) for k, v in obj.items()}
    if isinstance(obj, (list, tuple)): return [convert_numpy(i) for i in obj]
    return obj


def contains_any(value: str, keywords: List[str]) -> bool:
    return any(kw.lower() in value.lower() for kw in keywords)


def resize_frame(frame: np.ndarray) -> np.ndarray:
    h, w = frame.shape[:2]
    if w < CONFIG["min_dim"] or h < CONFIG["min_dim"]:
        s = CONFIG["min_dim"] / min(w, h)
        return cv2.resize(frame, (int(w*s), int(h*s)))
    if max(h, w) > CONFIG["max_dim"]:
        s = CONFIG["max_dim"] / max(h, w)
        return cv2.resize(frame, (int(w*s), int(h*s)))
    return frame


def decode_image(contents: bytes) -> np.ndarray:
    arr = np.frombuffer(contents, dtype=np.uint8)
    frame = cv2.imdecode(arr, cv2.IMREAD_COLOR)
    if frame is None:
        frame = cv2.imdecode(arr, cv2.IMREAD_GRAYSCALE)
        if frame is not None:
            frame = cv2.cvtColor(frame, cv2.COLOR_GRAY2BGR)
    if frame is None:
        raise HTTPException(status_code=400, detail="Cannot decode image")
    return frame


def clamp_bbox(raw_box, frame_shape) -> Optional[BBox]:
    h, w = frame_shape[:2]
    x1, y1, x2, y2 = [int(v) for v in raw_box]
    x1, x2 = min(x1, x2), max(x1, x2)
    y1, y2 = min(y1, y2), max(y1, y2)
    x1, y1 = max(0, min(x1, w-1)), max(0, min(y1, h-1))
    x2, y2 = max(0, min(x2, w)), max(0, min(y2, h))
    if x2-x1 < 15 or y2-y1 < 15: return None
    return [x1, y1, x2, y2]


def bbox_center(box: BBox) -> Tuple[float, float]:
    return ((box[0]+box[2])/2.0, (box[1]+box[3])/2.0)


def bbox_distance(box1: BBox, box2: BBox) -> float:
    x1, y1 = bbox_center(box1)
    x2, y2 = bbox_center(box2)
    return float(np.hypot(x1-x2, y1-y2))


def bbox_iou(box1: BBox, box2: BBox) -> float:
    x1, y1 = max(box1[0], box2[0]), max(box1[1], box2[1])
    x2, y2 = min(box1[2], box2[2]), min(box1[3], box2[3])
    if x2 <= x1 or y2 <= y1: return 0.0
    inter = (x2-x1)*(y2-y1)
    a1 = (box2[2]-box2[0])*(box2[3]-box2[1])
    a2 = (box2[2]-box2[0])*(box2[3]-box2[1])
    return inter/(a1+a2-inter) if (a1+a2-inter) > 0 else 0.0


def bbox_area(box: BBox) -> float:
    return (box[2] - box[0]) * (box[3] - box[1])


def normalize_plate_text(text: str) -> Optional[str]:
    cleaned = re.sub(r"[^A-Za-z0-9]", "", text).upper()
    corrections = {'0':'O','1':'I','5':'S','8':'B'}
    result = [corrections.get(c, c) if c.isdigit() and c in corrections else c for c in cleaned]
    cleaned = ''.join(result)
    if CONFIG["min_plate_length"] <= len(cleaned) <= CONFIG["max_plate_length"]:
        return cleaned
    return cleaned if len(cleaned) >= 3 else None


def read_plate_text(frame: np.ndarray, box: BBox) -> Optional[str]:
    if ocr_reader is None: return None
    x1, y1, x2, y2 = box
    crop = frame[y1:y2, x1:x2]
    if crop.size == 0: return None
    enhanced = preprocessor.enhance_for_ocr(crop)
    try:
        results = ocr_reader.readtext(enhanced, detail=1)
    except:
        return None
    best_text, best_conf = None, 0.0
    for _, text, conf in results:
        if conf < CONFIG["plate_confidence_threshold"]: continue
        n = normalize_plate_text(text)
        if n and conf > best_conf:
            best_text, best_conf = n, conf
    return best_text


def predict_boxes(model, frame, conf):
    detections = []
    if model is None: return detections
    processed = preprocessor.enhance_for_detection(frame)
    try:
        results = model(processed, conf=conf, iou=0.5, verbose=False, max_det=200)
        if results and results[0].boxes is not None:
            for item in results[0].boxes:
                box = clamp_bbox(tuple(item.xyxy[0].tolist()), frame.shape)
                if box is None: continue
                detections.append({
                    "bbox": box,
                    "confidence": round(float(item.conf[0]), 4),
                    "class_id": int(item.cls[0]),
                    "class_name": str(model.names[int(item.cls[0])]).lower(),
                })
    except Exception as e:
        print(f"  Prediction error: {e}")
    return detections


def is_bbox_inside(inner: BBox, outer: BBox, threshold: float = 0.5) -> bool:
    """Check if inner box is mostly inside outer box."""
    iou = bbox_iou(inner, outer)
    return iou > threshold


def analyze_single_frame(frame: np.ndarray) -> Dict[str, Any]:
    """Analyze a single frame for image. Uses fallback detection."""
    frame = resize_frame(frame)
    
    # Vehicle detection
    vehicles = []
    bike_boxes = []  # Track bike bboxes for triple riding analysis
    person_boxes = []  # Track person bboxes for overloading analysis
    
    for det in predict_boxes(vehicle_model, frame, CONFIG["vehicle_conf"]):
        name = det["class_name"]
        if contains_any(name, ["motor","bike","cycle","scooter","bicycle","motorcycle"]):
            vtype = "bike"
            bike_boxes.append(det["bbox"])
        elif contains_any(name, ["auto","rickshaw"]):
            vtype = "auto"
        elif contains_any(name, ["truck","lorry"]):
            vtype = "truck"
        elif contains_any(name, ["bus"]):
            vtype = "bus"
        elif contains_any(name, ["person","pedestrian","rider"]):
            vtype = "person"
            person_boxes.append(det["bbox"])
        else:
            vtype = "car"
        vehicles.append({"type": vtype, "bbox": det["bbox"], "confidence": det["confidence"]})
    
    if not vehicles:
        h, w = frame.shape[:2]
        vehicles.append({"type": "bike", "bbox": [int(w*0.1), int(h*0.3), int(w*0.9), int(h*0.9)], "confidence": 0.5})
    
    # Plate detection
    plates = []
    for det in predict_boxes(plate_model, frame, CONFIG["plate_conf"]):
        text = read_plate_text(frame, det["bbox"])
        plates.append({"bbox": det["bbox"], "confidence": det["confidence"], "text": text})
    
    if not plates:
        h, w = frame.shape[:2]
        for region in [[int(w*0.1),int(h*0.5),int(w*0.9),int(h*0.7)], [int(w*0.2),int(h*0.6),int(w*0.8),int(h*0.8)]]:
            text = read_plate_text(frame, region)
            if text:
                plates.append({"bbox": region, "confidence": 0.6, "text": text})
                break
    
    # Helmet detection
    helmet_violations = []
    for det in predict_boxes(helmet_model, frame, CONFIG["helmet_conf"]):
        if contains_any(det["class_name"], ["no_helmet","no-helmet","without","withouthelmet"]):
            helmet_violations.append({
                "type": "no_helmet",
                "bbox": det["bbox"],
                "confidence": det["confidence"],
                "message": "No helmet detected",
                "fine_amount": 1000
            })
    
    # Triple riding detection - directly use model output
    triple_violations = []
    triple_detections = predict_boxes(triple_model, frame, CONFIG["triple_conf"])
    
    for det in triple_detections:
        if contains_any(det["class_name"], ["triple","triple_riding"]) and det["confidence"] > 0.25:
            # Check for overlapping detections within same frame
            is_dup = False
            for existing in triple_violations:
                if bbox_iou(det["bbox"], existing["bbox"]) > 0.5:
                    is_dup = True
                    if det["confidence"] > existing["confidence"]:
                        existing["confidence"] = det["confidence"]
                        existing["bbox"] = det["bbox"]
                    break
            
            if not is_dup:
                triple_violations.append({
                    "type": "triple_riding",
                    "bbox": det["bbox"],
                    "confidence": det["confidence"],
                    "count": 3,
                    "message": "Triple riding detected",
                    "fine_amount": 2000
                })
    
    # Limit triple riding per frame
    if len(triple_violations) > 3:
        triple_violations = sorted(triple_violations, key=lambda x: x["confidence"], reverse=True)[:3]
    
    # Overloading detection - directly use model output
    overload_violations = []
    overload_detections = predict_boxes(overload_model, frame, CONFIG["overload_conf"])
    
    for det in overload_detections:
        if contains_any(det["class_name"], ["overload","overloaded","crowded","overload_auto"]):
            # Check for overlapping detections within same frame
            is_dup = False
            for existing in overload_violations:
                if bbox_iou(det["bbox"], existing["bbox"]) > 0.5:
                    is_dup = True
                    if det["confidence"] > existing["confidence"]:
                        existing["confidence"] = det["confidence"]
                        existing["bbox"] = det["bbox"]
                    break
            
            if not is_dup:
                overload_violations.append({
                    "type": "overloading",
                    "bbox": det["bbox"],
                    "confidence": det["confidence"],
                    "message": "Overloading detected",
                    "fine_amount": 5000
                })
    
    return {
        "vehicles": vehicles,
        "plates": plates,
        "violations": {
            "no_helmet": helmet_violations,
            "triple_riding": triple_violations,
            "overloading": overload_violations
        },
        "total_violations": len(helmet_violations) + len(triple_violations) + len(overload_violations)
    }


