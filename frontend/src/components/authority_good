// ==================== CCTV STREAM HOOK ====================
const useCCTVStream = () => {
  const [streamId, setStreamId] = useState(null);
  const [isStreaming, setIsStreaming] = useState(false);
  const [streamStats, setStreamStats] = useState(null);
  const [streamPreview, setStreamPreview] = useState(null);
  const [streamViolations, setStreamViolations] = useState({ no_helmet: 0, triple_riding: 0, overloading: 0 });
  const [streamTotalFine, setStreamTotalFine] = useState(0);
  const [elapsedTime, setElapsedTime] = useState(0);
  const [startTime, setStartTime] = useState(null);
  const [cctvDuration, setCctvDuration] = useState(300);
  const [activeSource, setActiveSource] = useState(null);
  
  const pollingRef = useRef(null);
  const previewIntervalRef = useRef(null);
  const timerRef = useRef(null);

  const startStream = async (source, maxDuration = 300) => {
    try {
      const id = `cctv_${Date.now()}`;
      setCctvDuration(maxDuration);
      setActiveSource(source);
      
      console.log(`🔌 Starting CCTV stream - ID: ${id}, Source: ${source}`);
      
      const response = await fetch('http://localhost:8000/cctv/start', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ 
          stream_id: id, 
          source: source,
          max_duration: maxDuration 
        })
      });
      
      const data = await response.json();
      console.log('📡 CCTV start response:', data);
      
      if (data.success) {
        setStreamId(id);
        setIsStreaming(true);
        setStartTime(Date.now());
        setElapsedTime(0);
        return { success: true, streamId: id };
      } else {
        return { success: false, error: data.message };
      }
    } catch (err) {
      console.error('Start stream error:', err);
      return { success: false, error: 'Cannot connect to AI server on port 8000' };
    }
  };

  const stopStream = useCallback(async () => {
    if (!streamId) return null;
    
    try {
      console.log(`🛑 Stopping CCTV stream: ${streamId}`);
      const response = await fetch('http://localhost:8000/cctv/stop', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ stream_id: streamId })
      });
      const data = await response.json();
      
      setIsStreaming(false);
      setStreamId(null);
      setStartTime(null);
      setActiveSource(null);
      
      if (pollingRef.current) clearInterval(pollingRef.current);
      if (previewIntervalRef.current) clearInterval(previewIntervalRef.current);
      if (timerRef.current) clearInterval(timerRef.current);
      
      return data.final_report || data;
    } catch (err) {
      console.error('Stop stream error:', err);
      setIsStreaming(false);
      setStreamId(null);
      setActiveSource(null);
      return null;
    }
  }, [streamId]);

  useEffect(() => {
    if (!isStreaming || !startTime) return;
    timerRef.current = setInterval(() => {
      const elapsed = Math.floor((Date.now() - startTime) / 1000);
      setElapsedTime(elapsed);
      if (elapsed >= cctvDuration) {
        console.log('⏰ Max duration reached, stopping stream');
        stopStream();
      }
    }, 1000);
    return () => { if (timerRef.current) clearInterval(timerRef.current); };
  }, [isStreaming, startTime, cctvDuration, stopStream]);

  useEffect(() => {
    if (!isStreaming || !streamId) return;

    pollingRef.current = setInterval(async () => {
      try {
        const res = await fetch(`http://localhost:8000/cctv/violations?stream_id=${streamId}`);
        const data = await res.json();
        if (data.stats) {
          setStreamStats(data.stats);
          setStreamViolations({
            no_helmet: data.stats.violations?.no_helmet || 0,
            triple_riding: data.stats.violations?.triple_riding || 0,
            overloading: data.stats.violations?.overloading || 0
          });
          setStreamTotalFine(data.total_fine || 0);
        }
      } catch (err) {}
    }, 2000);

    previewIntervalRef.current = setInterval(async () => {
      try {
        const res = await fetch(`http://localhost:8000/cctv/preview?stream_id=${streamId}`);
        const data = await res.json();
        if (data.image) setStreamPreview(data.image);
      } catch (err) {}
    }, 1000);

    return () => {
      if (pollingRef.current) clearInterval(pollingRef.current);
      if (previewIntervalRef.current) clearInterval(previewIntervalRef.current);
    };
  }, [isStreaming, streamId]);

  const formatTime = (seconds) => {
    const mins = Math.floor(seconds / 60);
    const secs = seconds % 60;
    return `${mins}:${secs.toString().padStart(2, '0')}`;
  };

  return {
    streamId, isStreaming, streamStats, streamPreview,
    streamViolations, streamTotalFine, elapsedTime, cctvDuration,
    activeSource, formatTime, startStream, stopStream
  };
};

// ==================== MAIN COMPONENT ====================
const AuthorityUploadViolation = () => {
  const [file, setFile] = useState(null);
  const [preview, setPreview] = useState(null);
  const [loading, setLoading] = useState(false);
  const [progress, setProgress] = useState(0);
  const [error, setError] = useState("");
  const [success, setSuccess] = useState("");
  const [detectedPlates, setDetectedPlates] = useState([]);
  const [violations, setViolations] = useState([]);
  const [plateConfirmed, setPlateConfirmed] = useState(false);
  const [editedPlateNumber, setEditedPlateNumber] = useState("");
  const [vehicleInfo, setVehicleInfo] = useState(null);
  const [processingTime, setProcessingTime] = useState(null);
  const [detectionMessages, setDetectionMessages] = useState([]);
  const [annotatedImage, setAnnotatedImage] = useState(null);
  const [mediaType, setMediaType] = useState(null);
  
  const [cameraActive, setCameraActive] = useState(false);
  const [cameraError, setCameraError] = useState("");
  const [dragActive, setDragActive] = useState(false);
  
  // CCTV state
  const [showCctvModal, setShowCctvModal] = useState(false);
  const [selectedCamera, setSelectedCamera] = useState(null);
  const [customSource, setCustomSource] = useState("");
  const [cctvDuration, setCctvDuration] = useState(5);
  
  // Camera preview in modal
  const [previewStreamActive, setPreviewStreamActive] = useState(false);
  const previewVideoRef = useRef(null);
  const previewStreamRef = useRef(null);
  
  // Available cameras detected on PC
  const [availableCameras, setAvailableCameras] = useState([]);
  const [detectingCameras, setDetectingCameras] = useState(false);

  const videoRef = useRef(null);
  const streamRef = useRef(null);
  const fileInputRef = useRef(null);
  const progressIntervalRef = useRef(null);

  const {
    streamId, isStreaming, streamStats, streamPreview,
    streamViolations, streamTotalFine, elapsedTime, cctvDuration: streamDuration,
    activeSource, formatTime, startStream, stopStream
  } = useCCTVStream();

  // ===== DETECT AVAILABLE CAMERAS ON PC =====
  const detectCameras = useCallback(async () => {
    setDetectingCameras(true);
    const cameras = [];
    
    try {
      const devices = await navigator.mediaDevices.enumerateDevices();
      const videoDevices = devices.filter(d => d.kind === 'videoinput');
      
      console.log('📷 Found video devices:', videoDevices.length);
      
      for (let i = 0; i < videoDevices.length; i++) {
        const device = videoDevices[i];
        console.log(`  Camera ${i}: ${device.label} (${device.deviceId})`);
        cameras.push({
          id: `webcam_${i}`,
          name: device.label || `Camera ${i + 1}`,
          source: String(i),  // IMPORTANT: Use the index as source for backend
          type: 'usb',
          deviceId: device.deviceId,
          groupId: device.groupId
        });
      }
      
      // If no labeled devices found via enumerateDevices
      if (cameras.length === 0) {
        console.log('No devices from enumerateDevices, trying direct access...');
        for (let i = 0; i < 5; i++) {
          try {
            const stream = await navigator.mediaDevices.getUserMedia({
              video: { width: { ideal: 640 }, height: { ideal: 480 } },
              audio: false
            });
            const tracks = stream.getTracks();
            if (tracks.length > 0) {
              const label = tracks[0].label || `Camera ${i}`;
              cameras.push({
                id: `webcam_${i}`,
                name: label,
                source: String(i),
                type: 'usb',
                deviceId: tracks[0].getSettings().deviceId || String(i)
              });
              tracks.forEach(t => t.stop());
              break; // Found one, that's enough
            }
          } catch (e) {
            // Try next
          }
        }
      }
    } catch (err) {
      console.error('Camera detection error:', err);
    }
    
    // IP camera presets
    const ipPresets = [
      {
        id: 'ip_front_gate',
        name: 'Front Gate IP Camera',
        source: 'rtsp://192.168.1.100:554/stream1',
        type: 'ip',
        icon: 'FaNetworkWired',
        description: 'Main entrance - RTSP stream'
      },
      {
        id: 'ip_parking',
        name: 'Parking Lot Camera',
        source: 'rtsp://192.168.1.101:554/stream1',
        type: 'ip',
        icon: 'FaNetworkWired',
        description: 'Parking area - RTSP stream'
      },
      {
        id: 'ip_highway',
        name: 'Highway Camera',
        source: 'rtsp://192.168.1.102:554/stream1',
        type: 'ip',
        icon: 'FaWifi',
        description: 'Highway monitoring'
      },
      {
        id: 'custom',
        name: 'Custom RTSP/URL',
        source: '',
        type: 'custom',
        icon: 'FaNetworkWired',
        description: 'Enter custom RTSP/HTTP URL'
      }
    ];
    
    const allCameras = [...cameras, ...ipPresets];
    console.log('✅ Total cameras available:', allCameras.length);
    console.log('USB Cameras:', cameras.map(c => `${c.name} (source: ${c.source})`));
    
    setAvailableCameras(allCameras);
    setDetectingCameras(false);
  }, []);

  // Auto-detect on mount
  useEffect(() => {
    detectCameras();
  }, [detectCameras]);

  // Cleanup on unmount
  useEffect(() => {
    return () => {
      if (streamRef.current) {
        streamRef.current.getTracks().forEach(t => t.stop());
      }
      if (previewStreamRef.current) {
        previewStreamRef.current.getTracks().forEach(t => t.stop());
      }
      if (progressIntervalRef.current) clearInterval(progressIntervalRef.current);
      if (isStreaming) stopStream();
    };
  }, [isStreaming, stopStream]);

  useEffect(() => {
    if (cameraActive && streamRef.current && videoRef.current) {
      videoRef.current.srcObject = streamRef.current;
    }
  }, [cameraActive]);

  // ===== START CAMERA PREVIEW IN MODAL =====
  const startCameraPreview = async (camera) => {
    console.log('📷 Starting preview for camera:', camera.name, 'deviceId:', camera.deviceId);
    
    // Stop any existing preview
    if (previewStreamRef.current) {
      previewStreamRef.current.getTracks().forEach(t => t.stop());
      previewStreamRef.current = null;
    }
    
    try {
      // Try with exact device ID first
      const constraints = {
        video: camera.deviceId 
          ? { 
              deviceId: { exact: camera.deviceId }, 
              width: { ideal: 640 }, 
              height: { ideal: 480 } 
            }
          : { 
              width: { ideal: 640 }, 
              height: { ideal: 480 } 
            },
        audio: false
      };
      
      console.log('Preview constraints:', constraints);
      
      const stream = await navigator.mediaDevices.getUserMedia(constraints);
      previewStreamRef.current = stream;
      
      // Set video source after a small delay to ensure element is ready
      setTimeout(() => {
        if (previewVideoRef.current) {
          previewVideoRef.current.srcObject = stream;
          console.log('✅ Preview stream set on video element');
        }
      }, 200);
      
      setPreviewStreamActive(true);
      console.log('✅ Preview active for:', camera.name);
    } catch (err) {
      console.error('Preview error with device ID:', err);
      // Fallback: try without specific device ID
      try {
        const stream = await navigator.mediaDevices.getUserMedia({
          video: { width: { ideal: 640 }, height: { ideal: 480 } },
          audio: false
        });
        previewStreamRef.current = stream;
        setTimeout(() => {
          if (previewVideoRef.current) {
            previewVideoRef.current.srcObject = stream;
          }
        }, 200);
        setPreviewStreamActive(true);
        console.log('✅ Preview active with default camera');
      } catch (err2) {
        console.error('Default preview error:', err2);
        setPreviewStreamActive(false);
      }
    }
  };

  const stopCameraPreview = () => {
    if (previewStreamRef.current) {
      previewStreamRef.current.getTracks().forEach(t => t.stop());
      previewStreamRef.current = null;
    }
    setPreviewStreamActive(false);
    console.log('📷 Preview stopped');
  };

  // ===== PROCESS DETECTION RESPONSE =====
  const processDetectionResponse = (response) => {
    const report = response.report || response;
    const counts = response.violation_counts || report.summary || {};
    
    if (response.detection_messages?.length > 0) {
      setDetectionMessages(response.detection_messages);
    } else {
      const messages = [];
      const total = counts.total || counts.total_violations || 0;
      if (total > 0) {
        messages.push(`🚨 Found ${total} violation(s)`);
        if ((counts.no_helmet || counts.no_helmet_cases) > 0) 
          messages.push(`🪖 ${counts.no_helmet || counts.no_helmet_cases} No Helmet - ₹1,000`);
        if ((counts.triple_riding || counts.triple_riding_cases) > 0) 
          messages.push(`🏍️ ${counts.triple_riding || counts.triple_riding_cases} Triple Riding - ₹2,000`);
        if ((counts.overloading || counts.overloading_cases) > 0) 
          messages.push(`🚛 ${counts.overloading || counts.overloading_cases} Overloading - ₹5,000`);
      } else {
        messages.push('✅ No violations detected');
      }
      messages.push(`🚗 ${counts.total_vehicles || report.all_vehicles?.length || 0} vehicles`);
      setDetectionMessages(messages);
    }
    
    const violationsData = response.violations || report.violations || {};
    const violationsList = [];
    
    (violationsData.no_helmet || []).forEach(v => violationsList.push({
      type: 'no_helmet', confidence: v.confidence || 0.85,
      description: v.message || 'No helmet detected',
      fine_amount: v.fine_amount || 1000, confirmed: false, saved: false, severity: 'high'
    }));
    (violationsData.triple_riding || []).forEach(v => violationsList.push({
      type: 'triple_riding', confidence: v.confidence || 0.85,
      description: v.message || `Triple riding (${v.count || 3} persons)`,
      fine_amount: v.fine_amount || 2000, confirmed: false, saved: false, severity: 'high'
    }));
    (violationsData.overloading || []).forEach(v => violationsList.push({
      type: 'overloading', confidence: v.confidence || 0.80,
      description: v.message || `Overloading (${v.count || 'multiple'} persons)`,
      fine_amount: v.fine_amount || 5000, confirmed: false, saved: false, severity: 'medium'
    }));
    
    setViolations(violationsList);
    
    const plates = (report.plates || []).filter(p => p.text).map(p => ({
      number: p.text, confidence: p.confidence || 0
    }));
    setDetectedPlates(plates);
    setPlateConfirmed(false);
    setEditedPlateNumber(plates[0]?.number || "");
    
    if (response.processing_time) setProcessingTime(response.processing_time);
    setMediaType(response.media_type || (file?.type?.startsWith('video/') ? 'video' : 'image'));
    
    if (response.annotated_image) setAnnotatedImage(`data:image/jpeg;base64,${response.annotated_image}`);
    
    const vehicles = report.all_vehicles || report.vehicles || [];
    setVehicleInfo({
      bikes: vehicles.filter(v => v.type === 'bike').length,
      cars: vehicles.filter(v => v.type === 'car').length,
      autos: vehicles.filter(v => v.type === 'auto').length,
      trucks: vehicles.filter(v => v.type === 'truck').length,
      total: vehicles.length
    });
    
    const total = violationsList.length;
    if (total > 0) {
      const parts = [];
      const h = violationsList.filter(v => v.type === 'no_helmet').length;
      const t = violationsList.filter(v => v.type === 'triple_riding').length;
      const o = violationsList.filter(v => v.type === 'overloading').length;
      if (h > 0) parts.push(`${h} helmet`);
      if (t > 0) parts.push(`${t} triple`);
      if (o > 0) parts.push(`${o} overload`);
      setSuccess(`✅ ${total} violation(s): ${parts.join(', ')}`);
    } else {
      setSuccess('✅ No violations detected.');
    }
  };

  // ===== CAMERA (SINGLE FRAME) =====
  const openCamera = async () => {
    setCameraError("");
    try {
      const stream = await navigator.mediaDevices.getUserMedia({
        video: { facingMode: "environment" }, audio: false
      });
      streamRef.current = stream;
      setCameraActive(true);
    } catch (err) {
      setCameraError("Cannot access camera.");
    }
  };

  const closeCamera = () => {
    if (streamRef.current) {
      streamRef.current.getTracks().forEach(t => t.stop());
      streamRef.current = null;
    }
    setCameraActive(false);
  };

  const captureLiveFrame = async () => {
    if (!videoRef.current) return null;
    const canvas = document.createElement("canvas");
    canvas.width = videoRef.current.videoWidth;
    canvas.height = videoRef.current.videoHeight;
    canvas.getContext("2d").drawImage(videoRef.current, 0, 0);
    return new Promise(r => canvas.toBlob(r, "image/jpeg", 0.95));
  };

  const handleLiveDetect = async () => {
    if (!videoRef.current) { setCameraError("Camera not ready."); return; }
    
    const blob = await captureLiveFrame();
    if (!blob) { setCameraError("Cannot capture."); return; }
    
    const tempFile = new File([blob], `capture-${Date.now()}.jpg`, { type: "image/jpeg" });
    setFile(tempFile); setPreview(URL.createObjectURL(tempFile));
    
    const formData = new FormData();
    formData.append("file", tempFile);
    setError(""); setSuccess(""); setLoading(true); setProgress(10);
    
    try {
      const response = await uploadAPI.uploadMedia(formData);
      setProgress(100);
      if (!response.success) { setError(response.error || "Failed."); return; }
      processDetectionResponse(response);
    } catch (err) { setError("Connection failed."); }
    finally { setLoading(false); }
  };

  // ===== CCTV STREAMING =====
  const handleSelectCamera = (camera) => {
    console.log('📷 Camera selected:', camera.name, '| Type:', camera.type, '| Source:', camera.source, '| deviceId:', camera.deviceId);
    setSelectedCamera(camera);
    
    if (camera.type === 'custom') {
      setCustomSource('');
      stopCameraPreview();
    } else if (camera.type === 'usb') {
      // For USB cameras, use the index as source for backend
      // The source should be "0", "1", "2" etc.
      console.log('✅ USB Camera source for backend:', camera.source);
      startCameraPreview(camera);
    } else {
      // IP camera - use the RTSP URL
      console.log('✅ IP Camera source:', camera.source);
      stopCameraPreview();
    }
  };

  const handleStartCCTV = async () => {
    if (!selectedCamera) {
      setError("Please select a camera first.");
      return;
    }
    
    // Determine the correct source to send to backend
    let source;
    if (selectedCamera.type === 'custom') {
      source = customSource;
      if (!source) {
        setError("Please enter a camera URL.");
        return;
      }
    } else if (selectedCamera.type === 'usb') {
      // CRITICAL: Use the camera's source (index like "0", "1", "2")
      source = selectedCamera.source;
    } else {
      // IP camera
      source = selectedCamera.source;
    }
    
    console.log('🚀 Starting CCTV with:');
    console.log('  Camera:', selectedCamera.name);
    console.log('  Type:', selectedCamera.type);
    console.log('  Source sent to backend:', source);
    console.log('  Duration:', cctvDuration, 'minutes');
    
    // Stop preview before starting CCTV
    stopCameraPreview();
    
    setError("");
    setSuccess(`📡 Starting CCTV with ${selectedCamera.name}...`);
    setLoading(true);
    
    const maxDuration = cctvDuration * 60;
    const result = await startStream(source, maxDuration);
    
    setLoading(false);
    
    if (result.success) {
      setSuccess(`📡 CCTV Live! Camera: ${selectedCamera.name} | Analyzing for ${cctvDuration} min.`);
      setShowCctvModal(false);
    } else {
      setError(result.error || "Failed to start CCTV stream.");
    }
  };

  const handleStopCCTV = async () => {
    setLoading(true);
    const report = await stopStream();
    setLoading(false);
    
    if (report) {
      const vd = report.violations || {};
      const list = [];
      (vd.no_helmet || []).forEach(v => list.push({
        type: 'no_helmet', confidence: v.confidence || 0.85,
        description: v.message || 'No helmet', fine_amount: v.fine_amount || 1000,
        confirmed: false, saved: false, severity: 'high'
      }));
      (vd.triple_riding || []).forEach(v => list.push({
        type: 'triple_riding', confidence: v.confidence || 0.85,
        description: v.message || 'Triple riding', fine_amount: v.fine_amount || 2000,
        confirmed: false, saved: false, severity: 'high'
      }));
      (vd.overloading || []).forEach(v => list.push({
        type: 'overloading', confidence: v.confidence || 0.80,
        description: v.message || 'Overloading', fine_amount: v.fine_amount || 5000,
        confirmed: false, saved: false, severity: 'medium'
      }));
      setViolations(list);
      setSuccess(`📡 CCTV stopped. ${list.length} violation(s) found.`);
    } else {
      setSuccess('📡 CCTV stopped.');
    }
  };

  // ===== FILE HANDLING =====
  const handleDrag = (e) => {
    e.preventDefault(); e.stopPropagation();
    setDragActive(e.type === "dragenter" || e.type === "dragover");
  };

  const handleDrop = (e) => {
    e.preventDefault(); e.stopPropagation(); setDragActive(false);
    const f = e.dataTransfer.files?.[0];
    if (f && (f.type.startsWith('image/') || f.type.startsWith('video/'))) {
      setFile(f); resetState(); setPreview(URL.createObjectURL(f));
    } else setError("Upload image/video only.");
  };

  const handleFileChange = (e) => {
    const f = e.target.files?.[0];
    if (!f) return;
    setFile(f); resetState(); setPreview(URL.createObjectURL(f));
  };

  const resetState = () => {
    setError(""); setSuccess(""); setDetectedPlates([]); setViolations([]);
    setVehicleInfo(null); setProcessingTime(null); setDetectionMessages([]);
    setAnnotatedImage(null); setMediaType(null);
    setPlateConfirmed(false); setEditedPlateNumber("");
  };

  const handleUpload = async () => {
    if (!file) { setError("Attach a file."); return; }
    resetState();
    const formData = new FormData();
    formData.append("file", file);
    const isVideo = file.type.startsWith('video/');
    
    try {
      setLoading(true); setProgress(5);
      if (isVideo) setSuccess("⏳ Processing video...");
      
      progressIntervalRef.current = setInterval(() => {
        setProgress(c => c < 30 ? c + 1 : c < 60 ? c + 0.5 : c < 85 ? c + 0.2 : c);
      }, isVideo ? 2000 : 220);

      const response = await uploadAPI.uploadMedia(formData);
      clearInterval(progressIntervalRef.current);
      setProgress(100);
      if (!response.success) { setError(response.error || "Failed."); return; }
      processDetectionResponse(response);
    } catch (err) {
      clearInterval(progressIntervalRef.current);
      setError("Connection failed.");
    } finally { setLoading(false); }
  };

  const clearFile = () => {
    setFile(null); setPreview(null); resetState();
    if (fileInputRef.current) fileInputRef.current.value = "";
  };

  // ===== VIOLATION ACTIONS =====
  const toggleConfirm = (i) => setViolations(prev => prev.map((v, idx) => idx === i ? { ...v, confirmed: !v.confirmed } : v));

  const saveViolation = async (i) => {
    const v = violations[i];
    if (!v.confirmed) { setError("Confirm first."); return; }
    try {
      const res = await violationsAPI.create({
        type: v.type, confidence: v.confidence, description: v.description,
        vehicleNumber: plateConfirmed ? editedPlateNumber : (detectedPlates[0]?.number || 'UNKNOWN'),
        status: "detected", fineAmount: v.fine_amount || 1000,
        timestamp: new Date().toISOString(), severity: v.severity || 'medium'
      });
      if (res.success) {
        setSuccess(`✅ Saved: ${v.type}`);
        setViolations(prev => prev.map((item, idx) => idx === i ? { ...item, saved: true } : item));
      } else setError(res.error || "Save failed.");
    } catch (err) { setError("Cannot save."); }
  };

  const saveAllViolations = async () => {
    const toSave = violations.filter(v => v.confirmed && !v.saved);
    if (!toSave.length) { setError("Confirm first."); return; }
    let saved = 0;
    for (const v of toSave) {
      try {
        const res = await violationsAPI.create({
          type: v.type, confidence: v.confidence, description: v.description,
          vehicleNumber: plateConfirmed ? editedPlateNumber : (detectedPlates[0]?.number || 'UNKNOWN'),
          status: "detected", fineAmount: v.fine_amount || 1000,
          timestamp: new Date().toISOString(), severity: v.severity || 'medium'
        });
        if (res.success) saved++;
      } catch (err) {}
    }
    if (saved > 0) {
      setSuccess(`✅ ${saved} saved!`);
      setViolations(prev => prev.map(v => v.confirmed ? { ...v, saved: true } : v));
      window.dispatchEvent(new CustomEvent('violationsUpdated'));
    } else setError("None saved.");
  };

  const fileTypeLabel = file?.type?.startsWith("video/") ? "video" : "image";
  const confirmedCount = violations.filter(v => v.confirmed).length;
  const totalFine = violations.reduce((s, v) => s + (v.fine_amount || 0), 0);

  return (
    <div className="authority-upload-violation">
      <Container fluid className="py-4 px-lg-5">
        {/* Header */}
        <div className="page-header mb-4">
          <div className="d-flex flex-column flex-md-row align-items-start justify-content-between">
            <div>
              <h1 className="page-title"><FaShieldAlt className="me-2" />Traffic Violation Detection</h1>
              <p className="page-subtitle">Upload evidence or connect CCTV cameras for AI detection</p>
            </div>
            <Badge className="authority-badge mt-2 mt-md-0"><FaShieldAlt /> Authority Portal</Badge>
          </div>
        </div>

        {/* CCTV LIVE BANNER */}
        {isStreaming && (
          <Alert style={{background: 'linear-gradient(135deg, #1a0033, #0d1b3e)', border: '2px solid #ff4444', borderRadius: '12px', color: '#eee'}}>
            <div className="d-flex align-items-center justify-content-between flex-wrap">
              <div>
                <FaBroadcastTower className="me-2 pulse-animation" style={{color: '#ff4444'}} />
                <strong style={{color: '#ff4444'}}>● CCTV LIVE</strong>
                {selectedCamera && <span> - {selectedCamera.name}</span>}
                <br /><small>
                  Source: {activeSource} | 
                  🪖{streamViolations.no_helmet} 🏍️{streamViolations.triple_riding} 🚛{streamViolations.overloading} | 
                  Fine: ₹{streamTotalFine.toLocaleString('en-IN')} | 
                  ⏱️ {formatTime(elapsedTime)} / {formatTime(streamDuration * 60)}
                </small>
              </div>
              <Button variant="danger" size="sm" onClick={handleStopCCTV} disabled={loading}>
                <FaStop /> Stop CCTV
              </Button>
            </div>
          </Alert>
        )}

        <Row className="g-4">
          <Col lg={7}>
            <Card className="upload-card">
              <Card.Body>
                <div className="card-header-custom">
                  <div className="header-icon"><FaUpload /></div>
                  <div><h3 className="card-title">Evidence Submission</h3><p className="card-subtitle">Upload or connect camera</p></div>
                </div>

                {/* Drag & Drop */}
                <div className={`drag-drop-zone ${dragActive ? 'active' : ''} ${file ? 'has-file' : ''}`}
                  onDragEnter={handleDrag} onDragLeave={handleDrag} onDragOver={handleDrag} onDrop={handleDrop}
                  onClick={() => fileInputRef.current?.click()}>
                  <input ref={fileInputRef} type="file" accept="image/*,video/*" onChange={handleFileChange} style={{display:'none'}} />
                  {!file ? (
                    <div className="drop-zone-content">
                      <FaFileImage className="upload-icon" size={48} />
                      <h4>Drag & Drop Evidence</h4>
                      <p>or <span className="browse-link">browse files</span></p>
                      <small>JPG, PNG, MP4, MOV, AVI</small>
                    </div>
                  ) : (
                    <div className="file-selected-content">
                      {fileTypeLabel === 'video' ? <FaVideo size={32} /> : <FaFileImage size={32} />}
                      <div><p className="file-name">{file.name}</p><small>{(file.size/1048576).toFixed(2)} MB</small></div>
                      <Button variant="link" onClick={e => {e.stopPropagation(); clearFile();}}><FaTimes /></Button>
                    </div>
                  )}
                </div>

                {/* Action Buttons */}
                <div className="action-buttons mt-3">
                  <Button variant="primary" onClick={handleUpload} disabled={loading || !file}>
                    {loading ? <Spinner size="sm" /> : <FaSearch />} {file?.type?.startsWith('video/') ? 'Process Video' : 'Analyze'}
                  </Button>
                  <Button variant="outline-secondary" onClick={cameraActive ? closeCamera : openCamera} disabled={loading || isStreaming}>
                    <FaCamera /> {cameraActive ? 'Close' : 'Single Capture'}
                  </Button>
                  <Button variant="info" onClick={() => { detectCameras(); setShowCctvModal(true); }} disabled={loading || isStreaming}>
                    <FaBroadcastTower /> {isStreaming ? 'CCTV Active...' : 'Live CCTV'}
                  </Button>
                  <Button variant="success" onClick={saveAllViolations} disabled={confirmedCount === 0 || loading}>
                    <FaSave /> Save ({confirmedCount})
                  </Button>
                </div>

                {/* Single Camera */}
                {cameraActive && !isStreaming && (
                  <div className="camera-section mt-3">
                    <video ref={videoRef} autoPlay playsInline muted className="camera-feed" />
                    <div className="d-flex gap-2 mt-2">
                      <Button variant="primary" onClick={handleLiveDetect} disabled={loading}><FaCamera /> Capture & Detect</Button>
                      <Button variant="outline-secondary" onClick={closeCamera}>Close</Button>
                    </div>
                    {cameraError && <Alert variant="warning" className="mt-2">{cameraError}</Alert>}
                  </div>
                )}

                {/* CCTV Live Preview */}
                {isStreaming && streamPreview && (
                  <div className="cctv-live-preview mt-3">
                    <h5><FaBroadcastTower className="me-2" style={{color:'#ff4444'}} />Live Feed <Badge bg="danger">● LIVE</Badge></h5>
                    <div style={{position:'relative'}}>
                      <img src={`data:image/jpeg;base64,${streamPreview}`} alt="Live" style={{width:'100%', borderRadius:'8px', border:'2px solid #ff4444'}} />
                      <div style={{position:'absolute', top:10, right:10, display:'flex', gap:5}}>
                        <Badge bg="danger">🪖{streamViolations.no_helmet}</Badge>
                        <Badge bg="warning">🏍️{streamViolations.triple_riding}</Badge>
                        <Badge style={{background:'#6a1b9a'}}>🚛{streamViolations.overloading}</Badge>
                      </div>
                    </div>
                  </div>
                )}

                {loading && !isStreaming && <div className="mt-3"><ProgressBar animated now={progress} /><small>Processing... {Math.round(progress)}%</small></div>}
                {error && <Alert variant="danger" className="mt-3">{error}</Alert>}
                {success && <Alert variant="success" className="mt-3">{success}</Alert>}

                {detectionMessages.length > 0 && (
                  <div className="detection-messages mt-3">
                    <h5><FaSearch /> Results</h5>
                    {detectionMessages.map((m, i) => <div key={i} className="msg-item">{m}</div>)}
                  </div>
                )}
                {processingTime && <Badge bg="info" className="mt-2"><FaClock /> {processingTime}s</Badge>}

                {preview && !cameraActive && !isStreaming && (
                  <div className="preview-section mt-3">
                    <h4>{mediaType === 'video' ? 'Video' : 'Image'} Preview</h4>
                    {annotatedImage ? (
                      <img src={annotatedImage} alt="Result" style={{maxWidth:'100%', borderRadius:'8px'}} />
                    ) : fileTypeLabel === 'video' ? (
                      <video controls src={preview} style={{maxWidth:'100%', borderRadius:'8px'}} />
                    ) : (
                      <img src={preview} alt="Preview" style={{maxWidth:'100%', borderRadius:'8px'}} />
                    )}
                  </div>
                )}
              </Card.Body>
            </Card>

            {/* Summary */}
            <Card className="mt-3">
              <Card.Body>
                <h4><FaIdCard className="me-2" />Summary</h4>
                <Row className="g-2 mb-3">
                  <Col xs={3}><div className="stat-box"><div className="stat-val">{violations.length}</div><small>Total</small></div></Col>
                  <Col xs={3}><div className="stat-box text-warning"><div className="stat-val">{violations.filter(v=>v.type==='no_helmet').length}</div><small>Helmet</small></div></Col>
                  <Col xs={3}><div className="stat-box text-danger"><div className="stat-val">{violations.filter(v=>v.type==='triple_riding').length}</div><small>Triple</small></div></Col>
                  <Col xs={3}><div className="stat-box text-purple"><div className="stat-val">{violations.filter(v=>v.type==='overloading').length}</div><small>Overload</small></div></Col>
                </Row>
                <h5>Fine: <span style={{color:'#ff5252'}}>₹{totalFine.toLocaleString('en-IN')}</span></h5>
                {vehicleInfo && (
                  <div className="mt-2">
                    {vehicleInfo.bikes > 0 && <Badge bg="primary" className="me-1">🏍️{vehicleInfo.bikes}</Badge>}
                    {vehicleInfo.cars > 0 && <Badge bg="success" className="me-1">🚗{vehicleInfo.cars}</Badge>}
                    {vehicleInfo.autos > 0 && <Badge bg="warning" className="me-1">🛺{vehicleInfo.autos}</Badge>}
                    {vehicleInfo.trucks > 0 && <Badge bg="secondary" className="me-1">🚛{vehicleInfo.trucks}</Badge>}
                  </div>
                )}
                {detectedPlates.length > 0 && (
                  <div className="mt-3">
                    <h6>Plates:</h6>
                    {detectedPlates.map((p, i) => <div key={i}><FaIdCard /> {p.number} <small>({(p.confidence*100).toFixed(0)}%)</small></div>)}
                    <div className="d-flex gap-2 mt-2">
                      <Form.Control value={editedPlateNumber} onChange={e => {setEditedPlateNumber(e.target.value.toUpperCase()); setPlateConfirmed(false);}} size="sm" />
                      <Button size="sm" variant={plateConfirmed ? "success" : "primary"}
                        onClick={() => {if(editedPlateNumber){setPlateConfirmed(true); setSuccess('✅ Plate confirmed!');}}}>
                        {plateConfirmed ? '✅' : 'Confirm'}
                      </Button>
                    </div>
                  </div>
                )}
              </Card.Body>
            </Card>
          </Col>

          {/* Right - Violations */}
          <Col lg={5}>
            <Card>
              <Card.Body>
                <h4><FaExclamationTriangle className="me-2" />Violations</h4>
                <small>{violations.length > 0 ? `${confirmedCount} confirmed` : 'Upload or start CCTV'}</small>
                {violations.length === 0 ? (
                  <div className="text-center py-4 text-muted"><FaFileImage size={48} /><p>No violations yet</p></div>
                ) : violations.map((v, i) => (
                  <div key={i} className={`p-3 mb-2 rounded ${v.confirmed ? 'border border-success' : ''}`}
                    style={{background:'#0d1b3e', border:'1px solid #1e2d50'}}>
                    <div className="d-flex justify-content-between">
                      <h6>{v.type==='no_helmet'?'🪖 No Helmet':v.type==='triple_riding'?'🏍️ Triple':'🚛 Overloading'}</h6>
                      <div>{v.confirmed && <Badge bg="success"><FaCheck /></Badge>}{v.saved && <Badge bg="info" className="ms-1"><FaSave /></Badge>}</div>
                    </div>
                    <p className="mb-1">{v.description}</p>
                    <div style={{height:6, background:'#333', borderRadius:3, marginBottom:5}}>
                      <div style={{width:`${v.confidence*100}%`, height:'100%', background:'#4fc3f7', borderRadius:3}} />
                    </div>
                    <small>{(v.confidence*100).toFixed(0)}% | ₹{v.fine_amount?.toLocaleString('en-IN')}</small>
                    <div className="mt-2">
                      <Button size="sm" variant={v.confirmed?"success":"outline-primary"} onClick={()=>toggleConfirm(i)} disabled={v.saved}>
                        {v.confirmed?'✅ Confirmed':'Confirm'}
                      </Button>
                      <Button size="sm" variant="outline-success" className="ms-2" onClick={()=>saveViolation(i)} disabled={!v.confirmed||v.saved}>
                        <FaSave /> {v.saved?'Saved':'Save'}
                      </Button>
                    </div>
                  </div>
                ))}
              </Card.Body>
            </Card>
            <Card className="mt-3">
              <Card.Body>
                <h6>📋 Fines</h6>
                <div>🪖 No Helmet: ₹1,000</div>
                <div>🏍️ Triple Riding: ₹2,000</div>
                <div>🚛 Overloading: ₹5,000</div>
              </Card.Body>
            </Card>
          </Col>
        </Row>

        {/* ==================== CCTV MODAL ==================== */}
        <Modal show={showCctvModal} onHide={() => {
          stopCameraPreview();
          setShowCctvModal(false);
        }} size="lg" centered>
          <Modal.Header closeButton style={{background:'#0d1b3e', color:'#e0e0e0', borderBottom:'1px solid #1a3a6b'}}>
            <Modal.Title><FaBroadcastTower className="me-2" />Start CCTV Live Analysis</Modal.Title>
          </Modal.Header>
          <Modal.Body style={{background:'#111936', color:'#e0e0e0'}}>
            {/* Detected USB Cameras */}
            <h6>📷 Detected USB Cameras on this PC</h6>
            {detectingCameras ? (
              <div className="text-center py-3"><Spinner size="sm" /> Detecting cameras...</div>
            ) : availableCameras.filter(c => c.type === 'usb').length > 0 ? (
              <div style={{display:'grid', gridTemplateColumns:'repeat(auto-fill, minmax(220px, 1fr))', gap:10, marginBottom:20}}>
                {availableCameras.filter(c => c.type === 'usb').map(camera => (
                  <div key={camera.id}
                    onClick={() => handleSelectCamera(camera)}
                    style={{
                      padding:15, cursor:'pointer', borderRadius:10,
                      background: selectedCamera?.id === camera.id ? '#1a3a6b' : '#0d1b3e',
                      border: selectedCamera?.id === camera.id ? '2px solid #4fc3f7' : '1px solid #1e2d50',
                      transition: 'all 0.2s'
                    }}>
                    <div className="d-flex align-items-center gap-2">
                      <FaUsb size={18} color={selectedCamera?.id === camera.id ? '#4fc3f7' : '#888'} />
                      <div style={{flex:1}}>
                        <div style={{fontWeight:'bold', fontSize:14}}>{camera.name}</div>
                        <small style={{color:'#888'}}>Source Index: <code style={{color:'#4fc3f7'}}>{camera.source}</code></small>
                        {camera.deviceId && (
                          <div><small style={{color:'#666', fontSize:10}}>ID: {camera.deviceId.substring(0, 20)}...</small></div>
                        )}
                      </div>
                    </div>
                    {selectedCamera?.id === camera.id && (
                      <Badge bg="success" style={{marginTop:8}}>✓ Selected</Badge>
                    )}
                  </div>
                ))}
              </div>
            ) : (
              <Alert style={{background:'#0d1b3e', borderColor:'#1a3a6b', color:'#e0e0e0'}}>
                No USB cameras found. Check permissions or try IP camera below.
              </Alert>
            )}

            <Button variant="outline-info" size="sm" onClick={detectCameras} className="mb-3" disabled={detectingCameras}>
              {detectingCameras ? <Spinner size="sm" /> : <FaRedo />} Refresh Cameras
            </Button>

            {/* LIVE CAMERA PREVIEW */}
            {previewStreamActive && (
              <div className="mb-3" style={{position:'relative', borderRadius:10, overflow:'hidden', border:'2px solid #4fc3f7'}}>
                <video 
                  ref={previewVideoRef}
                  autoPlay 
                  playsInline 
                  muted 
                  style={{width:'100%', maxHeight:'300px', background:'#000', borderRadius:8, display:'block'}}
                />
                <div style={{
                  position:'absolute', top:10, left:10,
                  background:'rgba(0,0,0,0.75)', padding:'5px 15px', borderRadius:20,
                  fontSize:13, color:'#4fc3f7', fontWeight:'bold'
                }}>
                  ● LIVE PREVIEW - {selectedCamera?.name}
                </div>
                <Button 
                  variant="danger" 
                  size="sm"
                  style={{position:'absolute', top:10, right:10, borderRadius:'50%', width:32, height:32, padding:0}}
                  onClick={stopCameraPreview}
                >
                  <FaTimes />
                </Button>
              </div>
            )}

            {/* IP Camera Presets */}
            <h6 className="mt-3">🌐 IP Camera / RTSP Presets</h6>
            <div style={{display:'grid', gridTemplateColumns:'repeat(auto-fill, minmax(220px, 1fr))', gap:10, marginBottom:20}}>
              {availableCameras.filter(c => c.type === 'ip' || c.type === 'custom').map(camera => (
                <div key={camera.id}
                  onClick={() => handleSelectCamera(camera)}
                  style={{
                    padding:15, cursor:'pointer', borderRadius:10,
                    background: selectedCamera?.id === camera.id ? '#1a3a6b' : '#0d1b3e',
                    border: selectedCamera?.id === camera.id ? '2px solid #4fc3f7' : '1px solid #1e2d50',
                    transition: 'all 0.2s'
                  }}>
                  <div className="d-flex align-items-center gap-2">
                    <FaNetworkWired size={18} color={selectedCamera?.id === camera.id ? '#4fc3f7' : '#888'} />
                    <div style={{flex:1}}>
                      <div style={{fontWeight:'bold', fontSize:14}}>{camera.name}</div>
                      <small style={{color:'#888'}}>{camera.description || 'IP Camera'}</small>
                      {camera.source && (
                        <code style={{fontSize:10, color:'#4fc3f7', display:'block', wordBreak:'break-all'}}>
                          {camera.source}
                        </code>
                      )}
                    </div>
                  </div>
                  {selectedCamera?.id === camera.id && (
                    <Badge bg="warning" style={{marginTop:8}}>✓ Selected</Badge>
                  )}
                </div>
              ))}
            </div>

            {/* Custom URL */}
            {selectedCamera?.type === 'custom' && (
              <Form.Group className="mb-3">
                <Form.Label>Enter Camera RTSP/HTTP URL</Form.Label>
                <Form.Control
                  type="text" value={customSource}
                  onChange={e => setCustomSource(e.target.value)}
                  placeholder="rtsp://192.168.1.100:554/stream1"
                  style={{background:'#0a0e27', color:'#e0e0e0', border:'1px solid #1e2d50'}}
                />
              </Form.Group>
            )}

            {/* Selected Camera Info */}
            {selectedCamera && (
              <Alert style={{background:'#0d1b3e', border:'1px solid #4fc3f7', color:'#e0e0e0'}}>
                <strong>✅ Selected:</strong> {selectedCamera.name}<br />
                <strong>Type:</strong> {selectedCamera.type === 'usb' ? 'USB Camera' : selectedCamera.type === 'ip' ? 'IP Camera (RTSP)' : 'Custom URL'}<br />
                <strong>Source:</strong> <code style={{color:'#4fc3f7'}}>
                  {selectedCamera.type === 'custom' ? (customSource || '(enter URL)') : selectedCamera.source}
                </code>
                {selectedCamera.type === 'usb' && previewStreamActive && (
                  <Badge bg="success" className="ms-2">Camera Preview Active ✓</Badge>
                )}
              </Alert>
            )}

            {/* Duration */}
            <h6 className="mt-3"><FaClock className="me-2" />Analysis Duration</h6>
            <div className="d-flex gap-2 flex-wrap">
              {[1,2,3,4,5].map(min => (
                <Button key={min} size="sm" variant={cctvDuration===min?'primary':'outline-secondary'}
                  onClick={()=>setCctvDuration(min)}>{min} min</Button>
              ))}
            </div>
            <small style={{color:'#888'}}>Auto-stops after {cctvDuration} minute(s)</small>
          </Modal.Body>
          <Modal.Footer style={{background:'#111936', borderTop:'1px solid #1a3a6b'}}>
            <Button variant="secondary" onClick={() => {
              stopCameraPreview();
              setShowCctvModal(false);
            }}>Cancel</Button>
            <Button 
              variant="primary" 
              onClick={handleStartCCTV}
              disabled={!selectedCamera || (selectedCamera.type==='custom' && !customSource)}
              size="lg"
            >
              <FaPlay className="me-1" /> Start CCTV ({cctvDuration} min) with {selectedCamera?.name || 'Camera'}
            </Button>
          </Modal.Footer>
        </Modal>
      </Container>
    </div>
  );
};

export default AuthorityUploadViolation;